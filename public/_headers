# Cloudflare заголовки (перенесено с netlify.toml при переходе на Cloudflare).
# Прокси /api и SPA-фолбэк — в wrangler.jsonc + worker/index.js.

/*
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload
  Permissions-Policy: camera=(self), microphone=(), geolocation=(), payment=(), usb=()
  # CSP. connect-src — точный allowlist реальных API + CDN-хосты фото. ВАЖНО: Service Worker
  # (workbox) кеширует картинки через fetch(), а fetch подчиняется connect-src — поэтому CDN
  # отображения фото (i.ibb.co/image.ibb.co/res.cloudinary.com/iili.io) обязаны быть здесь, иначе
  # при активном SW картинки рвутся (img-src их пропускает, но SW-fetch — нет).
  # img-src https: — пользовательские фото приходят с разных хостингов, не ограничиваем домен.
  # script-src 'unsafe-inline' — 2 инлайн-скрипта в index.html (тема + проверка SW); дальнейшее
  # ужесточение (хеши/вынос в файлы) — см. docs/security-audit-2026-06-25.md (H6).
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' https://static.cloudflareinsights.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' data: https://fonts.gstatic.com; img-src 'self' data: blob: https:; connect-src 'self' https://*.supabase.co wss://*.supabase.co https://api.imgbb.com https://i.ibb.co https://image.ibb.co https://api.cloudinary.com https://res.cloudinary.com https://freeimage.host https://iili.io https://api.novaposhta.ua https://vpic.nhtsa.dot.gov https://cloudflareinsights.com; frame-ancestors 'none'; base-uri 'self'; form-action 'self'; object-src 'none'; upgrade-insecure-requests
  Cache-Control: public, max-age=0, must-revalidate

# Хешированные ассеты — кэшируем навсегда (имя меняется при сборке)
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# Service Worker и workbox — без кэша, чтобы обновления подхватывались
/sw.js
  Cache-Control: no-cache, no-store, must-revalidate

/workbox-*.js
  Cache-Control: no-cache, no-store, must-revalidate

/manifest.webmanifest
  Cache-Control: public, max-age=86400
